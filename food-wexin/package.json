{
  "name": "smart-diet-miniapp",
  "version": "1.0.0",
  "description": "AI diet glasses WeChat mini program",
  "main": "main.js",
  "scripts": {
    "dev": "npm run serve",
    "serve": "cross-env NODE_ENV=development UNI_PLATFORM=h5 vue-cli-service uni-serve",
    "build": "cross-env NODE_ENV=production UNI_PLATFORM=h5 vue-cli-service uni-build",
    "build:mp-weixin": "node scripts/build-mp-weixin.js",
    "dev:mp-weixin": "node scripts/dev-mp-weixin-watch.js",
    "dev:mp-weixin:min": "cross-env UNI_MINIMIZE=true node scripts/dev-mp-weixin-watch.js",
    "fix:mp-config": "node scripts/fix-mp-project-config.js",
    "lint": "eslint --ext .js,.vue src"
  },
  "dependencies": {
    "@dcloudio/uni-app": "^3.0.0",
    "@dcloudio/uni-components": "^3.0.0",
    "@dcloudio/uni-h5": "^3.0.0",
    "@dcloudio/uni-mp-weixin": "^3.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.0.0",
    "@dcloudio/uni-automator": "^3.0.0",
    "@dcloudio/uni-cli-shared": "^3.0.0",
    "@dcloudio/uni-migration": "^3.0.0",
    "@dcloudio/uni-template-compiler": "^3.0.0",
    "@dcloudio/vite-plugin-uni": "^3.0.0",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "cross-env": "^7.0.3",
    "eslint": "^8.45.0",
    "eslint-plugin-vue": "^9.17.0",
    "postcss-comment": "^2.0.0",
    "sass": "^1.63.6",
    "sass-loader": "^13.3.2",
    "typescript": "^5.1.6",
    "vite": "^4.4.9"
  },
  "browserslist": [
    "android >= 4.4",
    "ios >= 9"
  ],
  "uni-app": {
    "scripts": {}
  }
}
