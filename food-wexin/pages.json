{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "进入首页",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/home/home",
      "style": {
        "navigationBarTitleText": "首页",
        "navigationStyle": "custom",
        "enablePullDownRefresh": true,
        "backgroundColor": "#f9f9f9"
      }
    },
    {
      "path": "pages/food-recognition/recognition",
      "style": {
        "navigationBarTitleText": "食物识别",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/reports/reports",
      "style": {
        "navigationBarTitleText": "饮食报告",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/setting/devices",
      "style": {
        "navigationBarTitleText": "设备管理",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/setting/profile",
      "style": {
        "navigationBarTitleText": "个人中心",
        "navigationStyle": "custom",
        "enablePullDownRefresh": false
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "饮食助手",
    "navigationBarBackgroundColor": "#07c160",
    "backgroundColor": "#f9f9f9",
    "backgroundColorTop": "#f9f9f9",
    "backgroundColorBottom": "#f9f9f9",
    "app-plus": {
      "titleView": false
    }
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#07c160",
    "borderStyle": "white",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/food-recognition/recognition",
        "text": "识别",
        "iconPath": "static/tabbar/recognition.png",
        "selectedIconPath": "static/tabbar/recognition-active.png"
      },
      {
        "pagePath": "pages/setting/devices",
        "text": "设备",
        "iconPath": "static/tabbar/devices.png",
        "selectedIconPath": "static/tabbar/devices-active.png"
      },
      {
        "pagePath": "pages/reports/reports",
        "text": "报告",
        "iconPath": "static/tabbar/reports.png",
        "selectedIconPath": "static/tabbar/reports-active.png"
      },
      {
        "pagePath": "pages/setting/profile",
        "text": "我的",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^ai-assistant$": "@/components/AiAssistant.vue",
      "^@/components/(.*)": "@/components/$1.vue",
      "^@/pages/(.*)": "@/pages/$1.vue",
      "^@/api/(.*)": "@/api/$1.js",
      "^@/utils/(.*)": "@/utils/$1.js",
      "^@/store/(.*)": "@/store/$1.ts"
    }
  },
  "subPackages": [
    {
      "root": "subpackages/auth",
      "pages": [
        {
          "path": "resiger/resiger",
          "style": {
            "navigationBarTitleText": "注册",
